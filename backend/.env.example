# AssetFlow Nexora Backend Environment
#
# These values are read by backend/src/main/resources/application.properties.
# Copy this file to .env for local development and update the password to match
# your local PostgreSQL user configured in pgAdmin 4.

# Spring Boot server
SERVER_PORT=8080

# PostgreSQL connection
# Database name is currently configured in application.properties as:
# Assetflow_Nexora
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=change-me
