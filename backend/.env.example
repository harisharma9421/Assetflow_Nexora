# AssetFlow Nexora Backend Environment
#
# These values are read by backend/src/main/resources/application.properties.
# Copy this file to .env for local development and update the password to match
# your local PostgreSQL user configured in pgAdmin 4.

# Spring Boot server
SERVER_PORT=8080

# PostgreSQL connection
# Database name is currently configured in application.properties as:
# Assetflow_Nexora
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=change-me

# JWT authentication
# Use a long random value in production.
JWT_SECRET=assetflow-local-development-secret-change-before-production
JWT_EXPIRATION_MINUTES=120

# Password reset tokens
PASSWORD_RESET_EXPIRATION_MINUTES=30

# Gmail SMTP email
# For Gmail, use an App Password instead of your normal Gmail password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-gmail-app-password
MAIL_FROM=your-email@gmail.com
FRONTEND_RESET_PASSWORD_URL=http://localhost:3000/reset-password
